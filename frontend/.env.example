EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_SITE_URL=https://example.com

# Public client-side IDs only. Never put server secrets in EXPO_PUBLIC_* values.
EXPO_PUBLIC_AGORA_APP_ID=
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GIPHY_API_KEY=your-public-giphy-client-key

# Supabase public URL and publishable/anon key only.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_WEB_REDIRECT_URI=https://example.com/auth/callback
EXPO_PUBLIC_SUPABASE_NATIVE_REDIRECT_URI=frontend://auth/callback
EXPO_PUBLIC_ENABLE_APPLE_SIGN_IN=1
