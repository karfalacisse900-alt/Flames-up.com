{
  "name": "flames-up-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env production --keep-vars",
    "db:migrate": "wrangler d1 execute flames-up-db --file=./migrations/0001_init.sql",
    "db:migrate:prod": "wrangler d1 execute flames-up-db --file=./migrations/0001_init.sql --remote",
    "db:perf-indexes:prod": "wrangler d1 execute DB --env production --remote --yes --file=./migrations/0019_production_performance_indexes.sql",
    "db:readiness:prod": "wrangler d1 execute DB --env production --remote --yes --file=./migrations/0020_production_readiness.sql",
    "db:admin-moderation:prod": "wrangler d1 execute DB --env production --remote --yes --file=./migrations/0021_admin_moderation.sql"
  },
  "dependencies": {
    "agora-token": "^2.0.5",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.24",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260524.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.94.0"
  }
}
